3.12.10,3.10.7,tkagg,20000,1.0,plot_minmax_t20000_thr1.0_noflag.svg,64193,plot_fill_t20000_thr1.0_noflag.svg,499030,plot_fill_t20000_thr1.0_noflag.pdf,189607,natural_should_simplify
3.12.10,3.10.7,tkagg,20000,1.0,plot_minmax_t20000_thr1.0_flag.svg,64193,plot_fill_t20000_thr1.0_flag.svg,499030,plot_fill_t20000_thr1.0_flag.pdf,189607,forced_should_simplify
3.12.10,3.10.7,tkagg,50000,0.0,plot_minmax_t50000_thr0.0_noflag.svg,2581043,plot_fill_t50000_thr0.0_noflag.svg,2576189,plot_fill_t50000_thr0.0_noflag.pdf,927086,natural_should_simplify
3.12.10,3.10.7,tkagg,50000,0.0,plot_minmax_t50000_thr0.0_flag.svg,2581043,plot_fill_t50000_thr0.0_flag.svg,2576189,plot_fill_t50000_thr0.0_flag.pdf,927086,forced_should_simplify
3.12.10,3.10.7,tkagg,50000,0.5,plot_minmax_t50000_thr0.5_noflag.svg,112547,plot_fill_t50000_thr0.5_noflag.svg,1817969,plot_fill_t50000_thr0.5_noflag.pdf,666444,natural_should_simplify
3.12.10,3.10.7,tkagg,50000,0.5,plot_minmax_t50000_thr0.5_flag.svg,112547,plot_fill_t50000_thr0.5_flag.svg,1817969,plot_fill_t50000_thr0.5_flag.pdf,666444,forced_should_simplify
3.12.10,3.10.7,tkagg,50000,1.0,plot_minmax_t50000_thr1.0_noflag.svg,62591,plot_fill_t50000_thr1.0_noflag.svg,1227880,plot_fill_t50000_thr1.0_noflag.pdf,456464,natural_should_simplify
3.12.10,3.10.7,tkagg,50000,1.0,plot_minmax_t50000_thr1.0_flag.svg,62591,plot_fill_t50000_thr1.0_flag.svg,1227880,plot_fill_t50000_thr1.0_flag.pdf,456464,forced_should_simplify
3.12.10,3.10.7,tkagg,100000,0.0,plot_minmax_t100000_thr0.0_noflag.svg,5151090,plot_fill_t100000_thr0.0_noflag.svg,5142043,plot_fill_t100000_thr0.0_noflag.pdf,1833004,natural_should_simplify
3.12.10,3.10.7,tkagg,100000,0.0,plot_minmax_t100000_thr0.0_flag.svg,5151090,plot_fill_t100000_thr0.0_flag.svg,5142043,plot_fill_t100000_thr0.0_flag.pdf,1833004,forced_should_simplify
3.12.10,3.10.7,tkagg,100000,0.5,plot_minmax_t100000_thr0.5_noflag.svg,113394,plot_fill_t100000_thr0.5_noflag.svg,3614529,plot_fill_t100000_thr0.5_noflag.pdf,1305043,natural_should_simplify
