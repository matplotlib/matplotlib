3.12.10,3.10.7,tkagg,100000,1.0,plot_minmax_t100000_thr1.0_noflag.svg,62642,plot_fill_t100000_thr1.0_noflag.svg,2445998,plot_fill_t100000_thr1.0_noflag.pdf,892933,natural_should_simplify
3.12.10,3.10.7,tkagg,100000,1.0,plot_minmax_t100000_thr1.0_flag.svg,62642,plot_fill_t100000_thr1.0_flag.svg,2445998,plot_fill_t100000_thr1.0_flag.pdf,892933,forced_should_simplify
"""

df = pd.read_csv(pd.io.common.StringIO(csv_text))

# vamos olhar só modo "natural_should_simplify" para não duplicar linhas
nat = df[df["mode"] == "natural_should_simplify"].copy()

def reduction_vs_thr(sub, col):
    base0 = sub[sub["thresh"] == 0.0][col].iloc[0]
    base05 = sub[sub["thresh"] == 0.5][col].iloc[0]
    base10 = sub[sub["thresh"] == 1.0][col].iloc[0]
    r05 = 1 - base05 / base0
    r10 = 1 - base10 / base0
    return base0, base05, base10, r05, r10

rows = []
for tmax in sorted(nat["tmax"].unique()):
    sub = nat[nat["tmax"] == tmax]
    for colname, label in [("size_minmax","minmax_svg"),
                           ("size_fill","fill_svg"),
                           ("size_pdf","fill_pdf")]:
        b0,b05,b10,r05,r10 = reduction_vs_thr(sub,colname)
        rows.append({
            "tmax": tmax,
            "target": label,
            "size@0.0": b0,
            "size@0.5": b05,
            "size@1.0": b10,
            "red_0.5_vs_0.0_%": round(r05*100,2),
            "red_1.0_vs_0.0_%": round(r10*100,2),
        })

summary = pd.DataFrame(rows)
summary