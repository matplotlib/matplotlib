import pandas as pd

csv_text = """py_ver,mpl_ver,backend,tmax,thresh,svg_minmax,size_minmax,svg_fill,size_fill,pdf_fill,size_pdf,mode
3.12.10,3.10.7,tkagg,20000,0.0,plot_minmax_t20000_thr0.0_noflag.svg,1040295,plot_fill_t20000_thr0.0_noflag.svg,1039862,plot_fill_t20000_thr0.0_noflag.pdf,385677,natural_should_simplify
3.12.10,3.10.7,tkagg,20000,0.0,plot_minmax_t20000_thr0.0_flag.svg,1040295,plot_fill_t20000_thr0.0_flag.svg,1039862,plot_fill_t20000_thr0.0_flag.pdf,385677,forced_should_simplify
3.12.10,3.10.7,tkagg,20000,0.5,plot_minmax_t20000_thr0.5_noflag.svg,114351,plot_fill_t20000_thr0.5_noflag.svg,736523,plot_fill_t20000_thr0.5_noflag.pdf,276830,natural_should_simplify
